# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
*.Dockerfile text eol=lf
.env text eol=lf
.env.example text eol=lf

# Binary files
*.pyc binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
